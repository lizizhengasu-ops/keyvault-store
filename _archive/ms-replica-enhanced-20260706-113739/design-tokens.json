  },
  "h2": {
    "fontSize": "34px",
    "fontWeight": "600",
    "color": "#000000",
    "lineHeight": "1.3"
  },
  "h3": {
    "fontSize": "24px",
    "fontWeight": "600",
    "color": "#000000",
    "lineHeight": "1.3"
  },
  "h4": {
    "fontSize": "20px",
