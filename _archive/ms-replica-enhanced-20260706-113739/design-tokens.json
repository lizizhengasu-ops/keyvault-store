  "spacingMd": "16px",
  "spacingLg": "24px",
  "spacingXl": "32px",
  "spacingXxl": "48px",
  "fontSans": "\"Segoe UI\", system-ui, sans-serif",
  "fontMono": "Consolas, monospace",
  "fontSizeSm": "12px",
