{
  "body": {
    "fontFamily": "\"Segoe UI\", system-ui, sans-serif",
    "fontSize": "15px",
    "color": "#000000",
    "bg": "#FFFFFF",
    "lineHeight": "1.6"
  },
  "h1": {
    "fontSize": "46px",
    "fontWeight": "600",
    "color": "#000000",
