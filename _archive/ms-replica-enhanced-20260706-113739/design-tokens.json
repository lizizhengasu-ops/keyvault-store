  "nav": {
    "bg": "#FFFFFF",
    "color": "#000000",
    "height": "48px",
    "borderBottom": "1px solid #E6E6E6"
  },
  "header": {
    "bg": "#FFFFFF",
    "color": "#000000"
  },
  "footer": {
    "bg": "#F2F2F2",
    "color": "#616161",
